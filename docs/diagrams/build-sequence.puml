@startuml
' VibeTags Build Sequence Diagram

skinparam backgroundColor #FFFFFF
skinparam sequence {
    ArrowColor #1565C0
    ActorBorderColor #1565C0
    LifeLineBorderColor #2196F3
    ParticipantBorderColor #2196F3
}

title VibeTags Build Sequence - Annotation Processing Flow

actor Developer
participant "javac\nCompiler" as Compiler
participant "AIGuardrailProcessor" as Processor
participant "File System" as FS
participant "AI Platform\nConfig Files" as AIFiles

== Build Initiation ==
Developer -> Compiler: mvn clean compile
activate Compiler
Compiler -> Compiler: Parse pom.xml\nResolve dependencies

== Annotation Discovery ==
Compiler -> Compiler: Discover AIGuardrailProcessor\nvia META-INF/services
note right: SPI registration

== Compilation Phase ==
Compiler -> Compiler: Compile Java sources
Compiler -> Processor: process(annotations, roundEnv)
activate Processor

== Processing Round ==
Processor -> Processor: Check: processingOver() || processed
alt Already processed or round over
    Processor --> Compiler: return false (no changes)
else First processing round
    Processor -> Processor: Set processed = true
    
    == Validation Phase ==
    Processor -> Processor: validateAnnotations()
    note right: Check for contradictions\n@AIDraft + @AILocked\nEmpty @AIAudit warnings
    
    == File Discovery Phase ==
    Processor -> Processor: buildServiceFileMap(root)
    note right: Map service keys\nto file paths
    Processor -> Processor: resolveActiveServices()
    note right: Check which files exist\n(file presence = opt-in)
    
    == Content Generation Phase ==
    Processor -> Processor: Initialize StringBuilders\nfor each platform
    
    loop For each @AILocked
        Processor -> Processor: Append to cursorRules
        Processor -> Processor: Append to claudeMd
        Processor -> Processor: Append to qwenMd
        Processor -> Processor: Append to other platforms
    end
    
    loop For each @AIContext
        Processor -> Processor: Append focus/avoids\nto all platforms
    end
    
    loop For each @AIIgnore
        Processor -> Processor: Append to ignore sections
        Processor -> Processor: Write to .qwenignore\n.cursorignore, etc.
    end
    
    loop For each @AIAudit
        Processor -> Processor: Append security checks\nto all platforms
    end
    
    loop For each @AIDraft
        Processor -> Processor: Append implementation tasks\nto all platforms
    end
    
    == File Writing Phase ==
    loop For each active service
        alt Content changed
            Processor -> FS: writeFileIfChanged(filePath, content)
            FS -> AIFiles: Write/update file
            Processor -> Compiler: NOTE: "updated - <file>"
        else Content unchanged
            Processor -> Compiler: NOTE: "no changes - <file>"
        end
    end
    
    == Orphaned Annotation Check ==
    Processor -> Processor: checkOrphanedAnnotations()
    note right: Warn if annotations used\nbut recommended files missing
    
    Processor --> Compiler: return false
end

deactivate Processor
Compiler --> Developer: BUILD SUCCESS
deactivate Compiler

== Developer Uses AI Tools ==
Developer -> AIFiles: Open QWEN.md, CLAUDE.md, etc.
note right: AI platforms read\ngenerated config files\nto enforce guardrails

@enduml
