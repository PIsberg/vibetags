@startuml
' VibeTags Class Diagram - Technical Architecture

skinparam backgroundColor #FFFFFF
skinparam class {
    BackgroundColor #E8F4FD
    BorderColor #2196F3
    ArrowColor #1565C0
}
skinparam stereotypeCBackgroundColor #BBDEFB
skinparam packageStyle rectangle

title VibeTags Architecture - Class Diagram

package "se.deversity.vibetags.annotations\n(vibetags-annotations.jar)" <<Annotations>> {

    interface AILocked <<annotation>> {
        + String reason()
    }

    interface AIContext <<annotation>> {
        + String focus()
        + String avoids()
    }

    interface AIDraft <<annotation>> {
        + String instructions()
    }

    interface AIAudit <<annotation>> {
        + String[] checkFor()
    }

    interface AIIgnore <<annotation>> {
        + String reason()
    }

    interface AIPrivacy <<annotation>> {
        + String reason()
    }

    interface AICore <<annotation>> {
        + String sensitivity()
        + String note()
    }

    interface AIPerformance <<annotation>> {
        + String constraint()
    }
}

package "se.deversity.vibetags.processor\n(vibetags-processor.jar)" <<Processor>> {

    class AIGuardrailProcessor <<orchestrator>> {
        - boolean processed
        - Path root
        - String projectName
        - Logger log
        - GuardrailFileWriter fileWriter
        - GranularRulesWriter granularWriter
        - AnnotationCollector collector

        + init(processingEnv) : void
        + process(annotations, roundEnv) : boolean
        - generateFiles() : void
    }

    class VibeTagsLogger {
        + {static} forRoot(root, logPath, logLevel) : Logger
        + {static} shutdown() : void
    }

    package "internal" <<Helpers>> {

        class AnnotationCollector {
            - Set<Element> lockedElements
            - Set<Element> contextElements
            - .. + 6 more annotation sets ..
            - boolean anyAnnotationsFound

            + collect(roundEnv) : boolean
            + reset() : void
            + locked() / context() / ... : Set<Element>
        }

        class AnnotationValidator <<utility>> {
            + {static} validate(messager, roundEnv) : void
        }

        class OrphanWarner <<utility>> {
            + {static} warnAboutOrphans(messager, log, active, ...) : void
        }

        class ServiceRegistry <<utility>> {
            + {static} buildServiceFileMap(root) : Map<String, Path>
            + {static} resolveActiveServices(messager, files) : Set<String>
        }

        class ElementNaming <<utility>> {
            + {static} elementPath(element) : String
            + {static} elementDisplayName(element) : String
            + {static} owningElement(element) : Element
        }

        class GuardrailContentBuilder {
            - AnnotationCollector collector
            - Set<String> activeServices
            - Map<Element, StringBuilder> elementRules
            - .. per-platform StringBuilders ..

            + build() : Result
            - appendLocked(e, ...) / appendContext(e, ...) / .. (8 in total)
        }

        class GuardrailFileWriter {
            + writeFileIfChanged(path, content, hasNewRules) : boolean
            + stripLegacyVibeTagsBlock(before) : String
            + cleanupGranularDirectory(dir, extension, exclude) : void
        }

        class GranularRulesWriter {
            - GuardrailFileWriter fileWriter

            + writeAll(elementRules, files, active) : Set<String>
            + cleanupAll(files, active, written) : void
        }
    }
}

package "javax.annotation.processing" <<JDK>> {

    abstract class AbstractProcessor {
        + getSupportedAnnotationTypes() : Set<String>
        + getSupportedSourceVersion() : SourceVersion
        + process(annotations, roundEnv) : boolean
    }

    interface Messager {
        + printMessage(kind, msg) : void
    }

    interface RoundEnvironment {
        + getElementsAnnotatedWith(annotation) : Set<Element>
        + processingOver() : boolean
    }
}

package "java.nio.file" <<JDK>> {
    class Path
    class Files
}

' Relationships
AbstractProcessor <|-- AIGuardrailProcessor : extends

AIGuardrailProcessor --> Messager : uses
AIGuardrailProcessor --> RoundEnvironment : uses
AIGuardrailProcessor --> VibeTagsLogger : uses

' Orchestrator → internal helpers
AIGuardrailProcessor --> AnnotationCollector : owns
AIGuardrailProcessor --> AnnotationValidator : delegates per-round validation
AIGuardrailProcessor --> ServiceRegistry : resolves active services
AIGuardrailProcessor --> GuardrailContentBuilder : builds per-platform content
AIGuardrailProcessor --> GuardrailFileWriter : writes / cleans files
AIGuardrailProcessor --> GranularRulesWriter : writes per-class .mdc/.md
AIGuardrailProcessor --> OrphanWarner : end-of-round orphan check

GuardrailContentBuilder --> AnnotationCollector : reads
GuardrailContentBuilder --> ElementNaming : formats names
GranularRulesWriter --> GuardrailFileWriter : composes
GuardrailFileWriter --> Path : writes to
GuardrailFileWriter --> Files : reads / writes

AILocked ..> AIGuardrailProcessor : processed by
AIContext ..> AIGuardrailProcessor : processed by
AIDraft ..> AIGuardrailProcessor : processed by
AIAudit ..> AIGuardrailProcessor : processed by
AIIgnore ..> AIGuardrailProcessor : processed by
AIPrivacy ..> AIGuardrailProcessor : processed by
AICore ..> AIGuardrailProcessor : processed by
AIPerformance ..> AIGuardrailProcessor : processed by

note right of AILocked
  Retention: SOURCE
  Target: TYPE, METHOD, FIELD
  Purpose: Prevent AI modifications
end note

note right of AIContext
  Retention: SOURCE
  Target: TYPE, METHOD
  Purpose: Guide AI behavior
end note

note right of AIDraft
  Retention: SOURCE
  Target: TYPE, METHOD
  Purpose: Request AI implementation
end note

note right of AIAudit
  Retention: SOURCE
  Target: TYPE, METHOD
  Purpose: Trigger security audits
end note

note right of AIIgnore
  Retention: SOURCE
  Target: TYPE, METHOD, FIELD
  Purpose: Exclude from AI context
end note

note right of AIPrivacy
  Retention: SOURCE
  Target: TYPE, METHOD, FIELD
  Purpose: PII guardrails — never log
  or expose runtime values
end note

note right of AICore
  Retention: SOURCE
  Target: TYPE, METHOD, FIELD
  Purpose: Mark sensitive core logic —
  change with extreme caution
end note

note right of AIPerformance
  Retention: SOURCE
  Target: TYPE, METHOD, FIELD
  Purpose: Hot-path constraint —
  O(n²) complexity forbidden
end note

note bottom of AIGuardrailProcessor
  @SupportedAnnotationTypes("*")
  @SupportedSourceVersion(RELEASE_11)

  Generates files for 12+ platforms:
  - Cursor (.cursorrules, .cursorignore, .cursor/rules/)
  - Claude (CLAUDE.md, .claudeignore)
  - Qwen (QWEN.md, .qwen/*)
  - Gemini (gemini_instructions.md, .aiexclude)
  - Codex (AGENTS.md, .codex/*)
  - Copilot (.github/copilot-instructions.md)
  - Aider (CONVENTIONS.md, .aiderignore)
  - Trae (.trae/rules/)
  - Roo (.roo/rules/)
  - Windsurf/LLM agents (llms.txt, llms-full.txt)

  File-existence opt-in model:
  Create signal file → VibeTags writes to it
  Delete signal file → VibeTags ignores it
end note

@enduml
