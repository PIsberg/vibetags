@startuml
' VibeTags Component Diagram

skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam defaultFontName "Segoe UI"

title VibeTags System Architecture

actor Developer
database "Build System\n(Maven/Gradle)" as MavenGradle

package "Developer Project" {
  rectangle "Java Source Files" as JavaSources
  note right of JavaSources
    Annotations used:
    @AILocked
    @AIContext
    @AIDraft
    @AIAudit
    @AIIgnore
  end note

  rectangle "vibetags-processor.jar" as VibetagsLib
  note bottom of VibetagsLib
    Annotations (SOURCE retention)
    AIGuardrailProcessor (JSR 269)
    META-INF/services/ registration
  end note
}

package "javac Compiler" {
  rectangle "Annotation\nProcessing" as AP
  rectangle "Java\nCompilation" as Compile
  rectangle "Bytecode\nGeneration" as Bytecode

  JavaSources --> AP
  VibetagsLib --> AP
  AP --> Compile
  Compile --> Bytecode

  note right of Bytecode
    Zero runtime overhead
    Annotations stripped
  end note
}

package "Generated AI Config Files" {
  rectangle "Qwen Files" as QwenFiles
  note right of QwenFiles
    QWEN.md
    .qwenignore
    .qwen/settings.json
    .qwen/commands/refactor.md
  end note

  rectangle "Cursor Files" as CursorFiles
  note right of CursorFiles
    .cursorrules
    .cursorignore
  end note

  rectangle "Claude Files" as ClaudeFiles
  note right of ClaudeFiles
    CLAUDE.md
    .claudeignore
  end note

  rectangle "Gemini Files" as GeminiFiles
  note right of GeminiFiles
    gemini_instructions.md
    .aiexclude
  end note

  rectangle "Codex Files" as CodexFiles
  note right of CodexFiles
    AGENTS.md
    .codex/config.toml
    .codex/rules/vibetags.rules
  end note

  rectangle "Copilot Files" as CopilotFiles
  note right of CopilotFiles
    .github/copilot-instructions.md
    .copilotignore
  end note
}

AP --> QwenFiles : Generate
AP --> CursorFiles : Generate
AP --> ClaudeFiles : Generate
AP --> GeminiFiles : Generate
AP --> CodexFiles : Generate
AP --> CopilotFiles : Generate

package "AI Platforms" {
  rectangle "Qwen IDE" as QwenIDE
  rectangle "Cursor IDE" as CursorIDE
  rectangle "Claude Code" as ClaudeCode
  rectangle "Gemini Code Assist" as GeminiCode
  rectangle "Codex CLI" as CodexCLI
  rectangle "GitHub Copilot" as GitHubCopilot

  QwenFiles --> QwenIDE : Read config
  CursorFiles --> CursorIDE : Read config
  ClaudeFiles --> ClaudeCode : Read config
  GeminiFiles --> GeminiCode : Read config
  CodexFiles --> CodexCLI : Read config
  CopilotFiles --> GitHubCopilot : Read config
}

note as OptInNote
  **Opt-in Mechanism**
  File presence = Opt-in
  Create empty file -> VibeTags populates
  Delete file -> VibeTags ignores
  No forced files on disk
end note

Developer --> JavaSources : Annotates
Developer --> MavenGradle : mvn compile
MavenGradle --> AP : Invokes compiler via SPI
Bytecode --> MavenGradle : Compiled classes

@enduml
