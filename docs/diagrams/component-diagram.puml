@startuml
' VibeTags Component Diagram - System Architecture

skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam defaultFontName "Segoe UI"

title VibeTags System Architecture - Component Diagram

package "Developer Project" {
    
    [Java Source Files] as JavaSources
    note right of JavaSources
      @AILocked
      @AIContext
      @AIDraft
      @AIAudit
      @AIIgnore
    end note
    
    [vibetags-processor.jar] as VibetagsLib
    note bottom of VibetagsLib
      Annotations (SOURCE retention)
      AIGuardrailProcessor (JSR 269)
      META-INF/services/ registration
    end note
}

package "javac Compiler" {
    
    [Annotation Processing] as AP
    [Java Compilation] as Compile
    [Bytecode Generation] as Bytecode
    
    JavaSources --> AP : Source code with annotations
    VibetagsLib --> AP : Provides processor
    AP --> Compile : Processed annotations
    Compile --> Bytecode : Clean bytecode\n(no annotations)
    
    note right of Bytecode
      Zero runtime overhead
      Annotations stripped
    end note
}

package "File System Output" {
    
    component "Qwen Files" as Qwen {
        [QWEN.md]
        [.qwenignore]
        [.qwen/settings.json]
        [.qwen/commands/refactor.md]
    }
    
    component "Cursor Files" as Cursor {
        [.cursorrules]
        [.cursorignore]
    }
    
    component "Claude Files" as Claude {
        [CLAUDE.md]
        [.claudeignore]
    }
    
    component "Gemini Files" as Gemini {
        [gemini_instructions.md]
        [.aiexclude]
    }
    
    component "Codex Files" as Codex {
        [AGENTS.md]
        [.codex/config.toml]
        [.codex/rules/vibetags.rules]
    }
    
    component "Copilot Files" as Copilot {
        [.github/copilot-instructions.md]
        [.copilotignore]
    }
}

AP --> Qwen : Generate
AP --> Cursor : Generate
AP --> Claude : Generate
AP --> Gemini : Generate
AP --> Codex : Generate
AP --> Copilot : Generate

package "AI Platforms" {
    
    [Qwen IDE] as QwenIDE
    [Cursor IDE] as CursorIDE
    [Claude Code] as ClaudeCode
    [Gemini Code Assist] as GeminiCode
    [Codex CLI] as CodexCLI
    [GitHub Copilot] as Copilot
    
    Qwen --> QwenIDE : Read config
    Cursor --> CursorIDE : Read config
    Claude --> ClaudeCode : Read config
    Gemini --> GeminiCode : Read config
    Codex --> CodexCLI : Read config
    Copilot --> Copilot : Read config
}

package "Opt-in Mechanism" {
    
    note as OptInNote
      File presence = Opt-in
      
      Create empty file → VibeTags populates
      Delete file → VibeTags ignores
      
      No forced files on disk
      Developer controls what exists
    end note
}

[Build System\nMaven/Gradle] as Build

Developer -> Build: mvn compile
Build --> javac Compiler : Invoke
Bytecode --> Build : Compiled classes

@enduml
