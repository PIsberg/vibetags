@startuml
' VibeTags Data Flow Diagram

skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"

title VibeTags Processing Flow - Detailed Data Flow

start

:Java Compiler invokes\nAIGuardrailProcessor.process();
note right: Triggered by @SupportedAnnotationTypes("*")

if (Already processed?) then (yes)
  :Return false;
  stop
else (no)
  :Set processed = true;
  
  == Validation Phase ==
  :validateAnnotations();
  if (@AIDraft + @AILocked\non same element?) then (yes)
    :WARNING: Contradictory annotations;
  endif
  if (@AIAudit with empty checkFor?) then (yes)
    :WARNING: Empty audit will be ignored;
  endif
  
  == Service Resolution ==
  :buildServiceFileMap(root);
  note right
    Returns Map<String, Path>:
    "qwen" → QWEN.md
    "qwen_ignore" → .qwenignore
    "qwen_settings" → .qwen/settings.json
    "qwen_refactor" → .qwen/commands/refactor.md
    "cursor" → .cursorrules
    ... (15 total services)
  end note
  
  :resolveActiveServices();
  note right
    Checks Files.exists() for each service
    Only active services get generated
    File presence = opt-in signal
  end note
  
  == Content Accumulation ==
  :Initialize StringBuilder per platform;
  
  partition "@AILocked Processing" {
    :Iterate @AILocked annotated elements;
    :Extract: className, reason;
    :Append to cursorRules, claudeMd,\nqwenMd, codexAgents, etc.;
  }
  
  partition "@AIContext Processing" {
    :Iterate @AIContext annotated elements;
    :Extract: className, focus, avoids;
    :Append contextual rules to all platforms;
  }
  
  partition "@AIIgnore Processing" {
    :Iterate @AIIgnore annotated elements;
    :Extract: className;
    :Append to ignore sections;
    :Write glob patterns to *.ignore files;
    note right
      **/ClassName.java
      Platform-specific exclusion lists
    end note
  }
  
  partition "@AIAudit Processing" {
    :Iterate @AIAudit annotated elements;
    :Extract: className, checkFor[];
    :Append security audit requirements;
    note right
      Platform-specific formats:
      - Markdown (Cursor, Qwen, Codex)
      - XML (Claude)
      - Markdown + Persona (Gemini)
    end note
  }
  
  partition "@AIDraft Processing" {
    :Iterate @AIDraft annotated elements;
    :Extract: className, instructions;
    :Append implementation tasks;
  }
  
  == Platform-Specific Finalization ==
  :Finalize Claude XML structure;
  :Add <rule> elements to Claude;
  :Close Qwen sections;
  
  == File Writing ==
  if (Service active?) then (yes)
    if (Content changed?) then (yes)
      :writeFileIfChanged(filePath, content);
      :Write UTF-8 encoded file;
      :Print NOTE: "updated - <file>";
    else (no)
      :Skip write (no changes);
      :Print NOTE: "no changes - <file>";
    endif
  else (no)
    :Skip service (not opted in);
  endif
  
  == Orphaned Annotation Check ==
  :checkOrphanedAnnotations();
  note right
    If @AIIgnore used but .qwenignore missing
    → WARNING for Qwen support
    If @AILocked used but .aiexclude missing
    → WARNING for Gemini/Codex support
  end note

endif

:Return false (do not claim annotations);
note right: Other processors must still see them

stop

@enduml
