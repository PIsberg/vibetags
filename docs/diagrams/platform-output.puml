@startuml
' VibeTags Platform Output Formats

skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam wrapWidth 300

title VibeTags - AI Platform Output Format Comparison

package "Same Annotation Input" as Input {

    component "@AILocked(reason = \"Critical payment logic\")\non PaymentProcessor" as Locked

    component "@AIContext(\n  focus = \"Memory optimization\",\n  avoids = \"java.util.regex\"\n) on StringParser" as Context

    component "@AIAudit(checkFor = {\n  \"SQL Injection\",\n  \"Thread Safety\"\n}) on DatabaseConnector" as Audit

    component "@AIIgnore on GeneratedMetadata" as Ignore

    component "@AIPrivacy(reason = \"PCI-DSS card data\")\non CreditCardStrategy.cardNumber" as Privacy

    component "@AICore(sensitivity = \"Critical\",\n  note = \"Battle-tested core\")\non PaymentEngine" as Core

    component "@AIPerformance(constraint = \"O(1) required\")\non HotPathRouter" as Performance
}

package "Platform-Specific Outputs" as Outputs {

    rectangle "Claude (CLAUDE.md)" as ClaudeOutput
    note right of ClaudeOutput
      **CLAUDE.md Format (XML):**
      <project_guardrails>
        <locked_files>
          <file path="PaymentProcessor">
            <reason>Critical payment logic</reason>
          </file>
        </locked_files>
        <audit_requirements>
          <file path="DatabaseConnector">
            <vulnerability_check>SQL Injection</vulnerability_check>
          </file>
        </audit_requirements>
        <pii_guardrails>
          <element path="CreditCardStrategy.cardNumber">
            <reason>PCI-DSS card data</reason>
          </element>
        </pii_guardrails>
        <core_elements>
          <element path="PaymentEngine">
            <sensitivity>Critical</sensitivity>
            <note>Battle-tested core</note>
          </element>
        </core_elements>
        <performance_constraints>
          <element path="HotPathRouter">
            <constraint>O(1) required</constraint>
          </element>
        </performance_constraints>
      </project_guardrails>
      <rule>Never propose edits to locked files.</rule>
    end note

    rectangle "Cursor (.cursorrules)" as CursorOutput
    note right of CursorOutput
      **.cursorrules Format (Markdown):**
      ## LOCKED FILES (DO NOT EDIT)
      * `PaymentProcessor` - Reason: Critical payment logic
      ## CONTEXTUAL RULES
      * `StringParser`
        * Focus: Memory optimization
      ## 🛡️ MANDATORY SECURITY AUDITS
      * `DatabaseConnector`
        - Required Checks: SQL Injection, Thread Safety
      ## 🚫 IGNORED ELEMENTS
      * `GeneratedMetadata`
      ## 🔐 PII / PRIVACY GUARDRAILS
      * `CreditCardStrategy.cardNumber` - PCI-DSS card data
      ## 🧠 CORE FUNCTIONALITY
      * `PaymentEngine` - Sensitivity: Critical
      ## ⚡ PERFORMANCE CONSTRAINTS
      * `HotPathRouter` - O(1) required
    end note

    rectangle "llms.txt (Windsurf / LLM Agents)" as LlmsOutput
    note right of LlmsOutput
      **llms.txt Format (llms.txt standard):**
      # This Project

      > AI guardrail rules generated by VibeTags.

      ## Locked Files
      - [PaymentProcessor](com.example.PaymentProcessor): ...

      ## Contextual Rules
      - [StringParser](com.example.StringParser): Focus - ...

      ## Security Audit Requirements
      - [DatabaseConnector](com.example.DatabaseConnector): ...

      ## PII / Privacy Guardrails
      - [CreditCardStrategy.cardNumber](...): PCI-DSS card data

      ## 🧠 Core Functionality
      - [PaymentEngine](...): Sensitivity: Critical. Note: ...

      ## ⚡ Performance Constraints
      - [HotPathRouter](...): O(1) required
    end note
}

Locked --> ClaudeOutput : Generates
Locked --> CursorOutput : Generates
Locked --> LlmsOutput : Generates

Context --> ClaudeOutput : Generates
Context --> CursorOutput : Generates
Context --> LlmsOutput : Generates

Audit --> ClaudeOutput : Generates
Audit --> CursorOutput : Generates
Audit --> LlmsOutput : Generates

Ignore --> ClaudeOutput : Generates
Ignore --> CursorOutput : Generates
Ignore --> LlmsOutput : Generates

Privacy --> ClaudeOutput : Generates
Privacy --> CursorOutput : Generates
Privacy --> LlmsOutput : Generates

Core --> ClaudeOutput : Generates
Core --> CursorOutput : Generates
Core --> LlmsOutput : Generates

Performance --> ClaudeOutput : Generates
Performance --> CursorOutput : Generates
Performance --> LlmsOutput : Generates

note as FormatNote
  Key Differences:

  **Claude**: XML-based structure
  - Strict XML tags for parsing
  - <rule> elements for enforcement
  - Nested hierarchical format

  **Cursor**: Markdown with emoji
  - Uses 🛡️ 🔐 🧠 ⚡ emoji headers
  - Standalone ignore file (.cursorignore)
  - Per-class granular rules (.cursor/rules/)

  **llms.txt**: llms.txt standard
  - Concise directory-style map
  - FQN link format [Name](FQN)
  - Windsurf Cascade reads it first
  - llms-full.txt for large-context LLMs

  All platforms receive the SAME annotation data
  but formatted for each platform's strengths
end note

@enduml
