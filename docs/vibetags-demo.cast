[0.007945, "o", "\u001b[1mVibeTags\u001b[0m — annotate once, all AI platforms stay in sync\r\n\r\n"]
[0.809498, "o", "\u001b[2m# 1. A class annotated with three guardrails\u001b[0m\r\n"]
[1.311448, "o", "\u001b[0;32m$\u001b[0m \u001b[1mcat src/main/java/com/example/PaymentService.java\u001b[0m\r\n"]
[1.714858, "o", "package com.example;\r\n\r\nimport se.deversity.vibetags.annotations.AIContract;\r\nimport se.deversity.vibetags.annotations.AILocked;\r\nimport se.deversity.vibetags.annotations.AIPrivacy;\r\n\r\n@AILocked(reason = \"PCI-DSS scope — do not modify without a security review\")\r\npublic class PaymentService {\r\n\r\n    @AIPrivacy(reason = \"Card data — never log or expose in suggestions\")\r\n    private final String cardToken;\r\n\r\n    public PaymentService(String cardToken) {\r\n        this.cardToken = cardToken;\r\n    }\r\n\r\n    @AIContract(reason = \"Bound by OpenAPI v2 contract with mobile-app and checkout-service\")\r\n    public String charge(double amount, String currency) {\r\n        return \"tx-\" + System.currentTimeMillis();\r\n    }\r\n}\r\n"]
[1.715061, "o", "\r\n"]
[3.018621, "o", "\u001b[2m# 2. Platform files are empty placeholders before compile\u001b[0m\r\n"]
[3.520647, "o", "\u001b[0;32m$\u001b[0m \u001b[1mwc -c CLAUDE.md .cursorrules AGENTS.md\u001b[0m\r\n"]
[3.924609, "o", "0 CLAUDE.md\r\n0 .cursorrules\r\n0 AGENTS.md\r\n0 total\r\n"]
[3.924835, "o", "\r\n"]
[5.22832, "o", "\u001b[2m# 3. mvn compile — VibeTags runs as part of javac\u001b[0m\r\n"]
[5.730208, "o", "\u001b[0;32m$\u001b[0m \u001b[1mmvn compile -q\u001b[0m\r\n"]
[8.378419, "o", "\u001b[0m\u001b[0m"]
[8.402964, "o", "\r\n"]
[9.706665, "o", "\u001b[2m# 4. CLAUDE.md now contains generated XML guardrails\u001b[0m\r\n"]
[10.208586, "o", "\u001b[0;32m$\u001b[0m \u001b[1msed -n '/VIBETAGS-START/,/VIBETAGS-END/p' CLAUDE.md\u001b[0m\r\n"]
[10.612399, "o", "<!-- VIBETAGS-START -->\r\n<!-- # Generated by VibeTags | https://github.com/PIsberg/vibetags -->\r\n<project_guardrails>\r\n  <locked_files>\r\n    <file path=\"com.example.PaymentService\">\r\n      <reason>PCI-DSS scope — do not modify without a security review</reason>\r\n    </file>\r\n  </locked_files>\r\n  <contextual_instructions>\r\n  </contextual_instructions>\r\n  <pii_guardrails>\r\n    <element path=\"com.example.PaymentService.cardToken\">\r\n"]
[10.612448, "o", "      <reason>Card data — never log or expose in suggestions</reason>\r\n    </element>\r\n  </pii_guardrails>\r\n\r\n<rule>\r\n  Never include runtime values of elements listed in <pii_guardrails> in logs, console output, external API calls, test fixtures, mock data, or code suggestions. Treat their values as strictly confidential.\r\n</rule>\r\n  <contract_signatures>\r\n    <element path=\"com.example.PaymentService.charge(double,java.lang.String)\">\r\n      <reason>Bound by OpenAPI v2 contract with mobile-app and checkout-service</reason>\r\n    </element>\r\n  </contract_signatures>\r\n\r\n"]
[10.612626, "o", "<rule>You may refactor the internal logic of elements listed in <contract_signatures>, but you MUST NOT change their public signatures: method names, parameter types, parameter order, return types, or checked exceptions.</rule>\r\n</project_guardrails>\r\n\r\n<rule>Never propose edits to files listed in <locked_files>.</rule>\r\n<!-- VIBETAGS-END -->\r\n"]
[10.613022, "o", "\r\n"]
[11.916475, "o", "\u001b[2m# 5. .cursorrules has the same rules in Cursor's format\u001b[0m\r\n"]
[12.418409, "o", "\u001b[0;32m$\u001b[0m \u001b[1msed -n '/VIBETAGS-START/,/VIBETAGS-END/p' .cursorrules\u001b[0m\r\n"]
[12.822253, "o", "# VIBETAGS-START\r\n# AUTO-GENERATED AI RULES\r\n# Generated by VibeTags | https://github.com/PIsberg/vibetags\r\n# Do not edit manually.\r\n\r\n## LOCKED FILES (DO NOT EDIT)\r\n* `com.example.PaymentService` - Reason: PCI-DSS scope — do not modify without a security review\r\n\r\n## CONTEXTUAL RULES\r\n\r\n## 🔒 PII / PRIVACY GUARDRAILS\r\n"]
[12.822436, "o", "The following elements handle Personally Identifiable Information (PII).\r\nNEVER include their runtime values in logs, console output, external API calls,\r\ntest fixtures, mock data, or code suggestions.\r\n\r\n* `com.example.PaymentService.cardToken` - Card data — never log or expose in suggestions\r\n\r\n## 🔐 CONTRACT-FROZEN SIGNATURES\r\nThe following elements have contract-frozen public signatures. You MAY change internal implementation logic, but MUST NOT modify method names, parameter types, parameter order, return types, or checked exceptions.\r\n\r\n* `com.example.PaymentService.charge(double,java.lang.String)` - Bound by OpenAPI v2 contract with mobile-app and checkout-service\r\n"]
[12.82249, "o", "# VIBETAGS-END\r\n"]
[12.822661, "o", "\r\n"]
[13.824445, "o", "\u001b[0;32m✓ 3 platform files updated — all from a single mvn compile\u001b[0m\r\n"]
