{"version": 2, "width": 82, "height": 26, "title": "VibeTags demo"}
[0.0, "o", "\u001b[2J\u001b[H"]
[0.05, "o", "\u001b[1mVibeTags\u001b[0m — annotate once, all AI platforms stay in sync\r\n"]
[0.1, "o", "\r\n"]
[1.0, "o", "\u001b[2m# 1. A class annotated with three guardrails\u001b[0m\r\n"]
[1.4, "o", "\u001b[0;32m$\u001b[0m \u001b[1mcat src/main/java/com/example/PaymentService.java\u001b[0m\r\n"]
[1.74, "o", "package com.example;\r\n"]
[1.78, "o", "\r\n"]
[1.82, "o", "import se.deversity.vibetags.annotations.AIContract;\r\n"]
[1.86, "o", "import se.deversity.vibetags.annotations.AILocked;\r\n"]
[1.9, "o", "import se.deversity.vibetags.annotations.AIPrivacy;\r\n"]
[1.94, "o", "\r\n"]
[1.98, "o", "@AILocked(reason = \"PCI-DSS scope — do not modify without a security review\")\r\n"]
[2.02, "o", "public class PaymentService {\r\n"]
[2.06, "o", "\r\n"]
[2.1, "o", "    @AIPrivacy(reason = \"Card data — never log or expose in suggestions\")\r\n"]
[2.14, "o", "    private final String cardToken;\r\n"]
[2.18, "o", "\r\n"]
[2.22, "o", "    public PaymentService(String cardToken) { this.cardToken = cardToken; }\r\n"]
[2.26, "o", "\r\n"]
[2.3, "o", "    @AIContract(reason = \"Bound by OpenAPI v2 contract with mobile-app\")\r\n"]
[2.34, "o", "    public String charge(double amount, String currency) {\r\n"]
[2.38, "o", "        return \"tx-\" + System.currentTimeMillis();\r\n"]
[2.42, "o", "    }\r\n"]
[2.46, "o", "}\r\n"]
[2.51, "o", "\r\n"]
[3.81, "o", "\u001b[2m# 2. Placeholder files — empty before compile\u001b[0m\r\n"]
[4.21, "o", "\u001b[0;32m$\u001b[0m \u001b[1mwc -c CLAUDE.md .cursorrules AGENTS.md\u001b[0m\r\n"]
[4.55, "o", "       0 CLAUDE.md\r\n"]
[4.59, "o", "       0 .cursorrules\r\n"]
[4.63, "o", "       0 AGENTS.md\r\n"]
[4.67, "o", "       0 total\r\n"]
[4.72, "o", "\r\n"]
[5.72, "o", "\u001b[2m# 3. mvn compile -q  — VibeTags runs as part of javac\u001b[0m\r\n"]
[6.12, "o", "\u001b[0;32m$\u001b[0m \u001b[1mmvn compile -q\u001b[0m\r\n"]
[8.97, "o", "\r\n"]
[9.77, "o", "\u001b[2m# 4. CLAUDE.md — generated XML guardrails\u001b[0m\r\n"]
[10.17, "o", "\u001b[0;32m$\u001b[0m \u001b[1msed -n '/VIBETAGS-START/,/VIBETAGS-END/p' CLAUDE.md\u001b[0m\r\n"]
[10.51, "o", "<!-- VIBETAGS-START -->\r\n"]
[10.55, "o", "<!-- # Generated by VibeTags | https://github.com/PIsberg/vibetags -->\r\n"]
[10.59, "o", "<project_guardrails>\r\n"]
[10.63, "o", "  <locked_files>\r\n"]
[10.67, "o", "    <file path=\"com.example.PaymentService\">\r\n"]
[10.71, "o", "      <reason>PCI-DSS scope — do not modify without a security review</reason>\r\n"]
[10.75, "o", "    </file>\r\n"]
[10.79, "o", "  </locked_files>\r\n"]
[10.83, "o", "  <pii_guardrails>\r\n"]
[10.87, "o", "    <element path=\"com.example.PaymentService.cardToken\">\r\n"]
[10.91, "o", "      <reason>Card data — never log or expose in suggestions</reason>\r\n"]
[10.95, "o", "    </element>\r\n"]
[10.99, "o", "  </pii_guardrails>\r\n"]
[11.03, "o", "  <contract_signatures>\r\n"]
[11.07, "o", "    <element path=\"com.example.PaymentService.charge(double,java.lang.String)\">\r\n"]
[11.11, "o", "      <reason>Bound by OpenAPI v2 contract with mobile-app</reason>\r\n"]
[11.15, "o", "    </element>\r\n"]
[11.19, "o", "  </contract_signatures>\r\n"]
[11.23, "o", "</project_guardrails>\r\n"]
[11.27, "o", "<rule>Never propose edits to files listed in &lt;locked_files&gt;.</rule>\r\n"]
[11.31, "o", "<!-- VIBETAGS-END -->\r\n"]
[11.36, "o", "\r\n"]
[12.66, "o", "\u001b[2m# 5. .cursorrules — same guardrails in Cursor's format\u001b[0m\r\n"]
[13.06, "o", "\u001b[0;32m$\u001b[0m \u001b[1msed -n '/VIBETAGS-START/,/VIBETAGS-END/p' .cursorrules\u001b[0m\r\n"]
[13.4, "o", "# VIBETAGS-START\r\n"]
[13.44, "o", "## LOCKED FILES (DO NOT EDIT)\r\n"]
[13.48, "o", "* `com.example.PaymentService`\r\n"]
[13.52, "o", "  PCI-DSS scope — do not modify without a security review\r\n"]
[13.56, "o", "\r\n"]
[13.6, "o", "## 🔒 PII / PRIVACY GUARDRAILS\r\n"]
[13.64, "o", "* `com.example.PaymentService.cardToken`\r\n"]
[13.68, "o", "  Card data — never log or expose in suggestions\r\n"]
[13.72, "o", "\r\n"]
[13.76, "o", "## 🔐 CONTRACT-FROZEN SIGNATURES\r\n"]
[13.8, "o", "* `com.example.PaymentService.charge(double,java.lang.String)`\r\n"]
[13.84, "o", "  Bound by OpenAPI v2 contract with mobile-app and checkout-service\r\n"]
[13.88, "o", "# VIBETAGS-END\r\n"]
[13.93, "o", "\r\n"]
[14.43, "o", "\u001b[0;32m✓ 3 platform files updated — from a single mvn compile\u001b[0m\r\n"]
