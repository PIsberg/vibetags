<?xml version="1.0"?>
<ruleset name="VibeTags Custom PMD Ruleset"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Custom PMD ruleset for VibeTags.
    </description>

    <!-- Import category/java/errorprone.xml, excluding rules that are deliberately not followed or suppressed -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="AvoidCatchingThrowable"/>
        <exclude name="CloseResource"/>
        <exclude name="AssignmentInOperand"/>
        <exclude name="EmptyCatchBlock"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="ReturnEmptyCollectionRatherThanNull"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="NullAssignment"/>
    </rule>

    <!-- Import category/java/bestpractices.xml, excluding rules that are deliberately not followed or suppressed -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="GuardLogStatement"/>
        <exclude name="SystemPrintln"/>
        <exclude name="AvoidStringBufferField"/>
        <exclude name="UnusedPrivateField"/>
        <exclude name="UseVarargs"/>
        <exclude name="LiteralsFirstInComparisons"/>
        <exclude name="UnusedFormalParameter"/>
        <exclude name="ExhaustiveSwitchHasDefault"/>
    </rule>
</ruleset>
